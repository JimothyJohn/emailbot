#!/bin/bash
set -e

# --- Auto Dependency Setup ---
# Check and install 'uv'
if ! command -v uv &> /dev/null; then
    echo "uv could not be found. Automatically installing..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.cargo/bin:$HOME/.local/bin:$PATH"
fi

# Check and install 'sam'
if ! command -v sam &> /dev/null; then
    echo "aws-sam-cli could not be found. Automatically installing..."
    if [ "$(uname)" == "Darwin" ]; then
        if ! command -v brew &> /dev/null; then
            echo "Error: Homebrew not found! Please install Homebrew first to auto-install SAM."
            exit 1
        fi
        brew tap aws/tap
        brew install aws-sam-cli
    else
        echo "Error: Please manually install aws-sam-cli for your OS."
        exit 1
    fi
fi
# -----------------------------

# Default values
DEPLOY=false

while getopts ":p" opt; do
  case ${opt} in
    p )
      DEPLOY=true
      ;;
    \? )
      echo "Usage: Quickstart [-p]"
      exit 1
      ;;
  esac
done

echo "Syncing uv lockfile..."
uv sync

echo "Running checks..."
uv run pytest -m unit || uv run pytest

echo "Validating SAM template..."
sam validate

if [ "$DEPLOY" = true ]; then
  echo "Exporting uv lockfile to requirements.txt for SAM..."
  uv export --format requirements-txt --no-hashes --no-emit-project > requirements.txt
  
  echo "Bundling assets into compute payload..."
  cp PERSONALITY.md assistant/
  
  echo "Building via SAM..."
  sam build
  
  echo "Deploying via SAM..."
  sam deploy
fi
